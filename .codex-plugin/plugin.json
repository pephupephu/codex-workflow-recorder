{
  "name": "workflow-recorder",
  "display_name": "Workflow Recorder & Replayer",
  "description": "Record mouse/keyboard actions and replay them automatically on Windows. Ideal for ComfyUI workflow automation and other desktop tasks.",
  "author": "pephupephu",
  "version": "1.1.0",
  "scripts": {
    "record": {
      "command": "compile-and-start.ps1",
      "description": "Start recording mouse/keyboard actions"
    },
    "replay": {
      "command": "replay-recording.ps1",
      "description": "Replay a recorded workflow"
    },
    "list": {
      "command": "list-recordings.ps1",
      "description": "List all recordings"
    }
  },
  "icon": "https://cdn.jsdelivr.net/gh/pephupephu/codex-workflow-recorder@main/assets/icon.png",
  "license": "MIT",
  "platform": "windows",
  "repository": "https://github.com/pephupephu/codex-workflow-recorder"
}